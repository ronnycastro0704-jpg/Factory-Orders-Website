generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  role         UserRole @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
}

model ApprovedCustomer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([active])
}

model Product {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description  String?
  sku          String?
  imageUrl     String?
  basePrice    Decimal       @db.Decimal(10, 2)
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  optionGroups OptionGroup[]
  orderItems   OrderItem[]
}

model OptionGroup {
  id           String          @id @default(cuid())
  productId    String
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  type         OptionGroupType @default(SINGLE_SELECT)
  required     Boolean         @default(false)
  displayOrder Int             @default(0)
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  choices      OptionChoice[]

  @@unique([productId, slug])
}

model OptionChoice {
  id                      String      @id @default(cuid())
  optionGroupId           String
  optionGroup             OptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)
  label                   String
  value                   String?
  description             String?
  frameNeededCode         String?
  isBodyLeather           Boolean     @default(false)
  imageUrl                String?
  priceDelta              Decimal     @default(0) @db.Decimal(10, 2)
  leatherInventoryUsage   Decimal?    @db.Decimal(10, 2)

  usesLeatherGrades       Boolean     @default(false)
  isQuickPick             Boolean     @default(false)
  allowsLaseredBrand      Boolean     @default(false)
  isBinaryOption          Boolean     @default(false)
  appliesLeatherSurcharge Boolean     @default(true)
  gradeAUpcharge          Decimal?    @db.Decimal(10, 2)
  gradeBUpcharge          Decimal?    @db.Decimal(10, 2)
  gradeEMBUpcharge        Decimal?    @db.Decimal(10, 2)
  gradeHOHUpcharge        Decimal?    @db.Decimal(10, 2)
  gradeAxisUpcharge       Decimal?    @db.Decimal(10, 2)
  gradeBuffaloUpcharge    Decimal?    @db.Decimal(10, 2)
  comUpcharge             Decimal?    @db.Decimal(10, 2)

  displayOrder            Int         @default(0)
  active                  Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  @@index([optionGroupId])
}

model Order {
  id                      String                  @id @default(cuid())
  orderNumber             String                  @unique
  customerName            String
  customerEmail           String
  customerPhone           String?
  poNumber                String?
  status                  OrderStatus             @default(DRAFT)
  subtotal                Decimal                 @default(0) @db.Decimal(10, 2)
  total                   Decimal                 @default(0) @db.Decimal(10, 2)
  notes                   String?
  sentToFactoryAt         DateTime?
  dueDate                 DateTime?
  priority                OrderPriority           @default(NORMAL)
  pickedUp                Boolean                 @default(false)
  pickedUpAt              DateTime?
  overallProductionStatus ProductionOverallStatus @default(NEW)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  quantity                Int                     @default(1)

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  items                 OrderItem[]
  revisions             OrderRevision[]
  emailLogs             EmailLog[]
  sheetSyncLogs         SheetSyncLog[]
  productionLines       ProductionLine[]
  quantityLedgerEntries QuantityLedger[]

  @@index([userId])
}

model OrderItem {
  id                  String               @id @default(cuid())
  orderId             String
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId           String
  product             Product              @relation(fields: [productId], references: [id])
  productNameSnapshot String
  basePriceSnapshot   Decimal              @db.Decimal(10, 2)
  quantity            Int                  @default(1)
  lineTotal           Decimal              @default(0) @db.Decimal(10, 2)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  selections          OrderItemSelection[]

  @@index([orderId])
}

model OrderItemSelection {
  id                            String    @id @default(cuid())
  orderItemId                   String
  orderItem                     OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  optionGroupNameSnapshot       String
  optionChoiceNameSnapshot      String
  optionChoiceImageUrlSnapshot String?
  leatherNameSnapshot          String?
  leatherGradeSnapshot         String?
  leatherImageUrlSnapshot      String?
  laseredBrandImageUrlSnapshot String?
  priceDeltaSnapshot            Decimal   @default(0) @db.Decimal(10, 2)
  leatherInventoryUsageSnapshot Decimal?  @db.Decimal(10, 2)
  createdAt                     DateTime  @default(now())

  @@index([orderItemId])
}

model OrderRevision {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  revisionNumber Int
  changedBy      String?
  changeReason   String?
  beforeJson     Json
  afterJson      Json
  createdAt      DateTime @default(now())

  @@unique([orderId, revisionNumber])
  @@index([orderId])
}

model EmailLog {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventType    String
  recipient    String
  subject      String?
  status       String
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([orderId])
}

model SheetSyncLog {
  id               String   @id @default(cuid())
  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  spreadsheetId    String?
  worksheetName    String?
  spreadsheetRowId String?
  status           String
  errorMessage     String?
  createdAt        DateTime @default(now())

  @@index([orderId])
}

model Employee {
  id         String             @id @default(cuid())
  name       String
  department EmployeeDepartment @default(GENERAL)
  active     Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model ProductionLine {
  id                       String                  @id @default(cuid())
  orderId                  String
  order                    Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productNameSnapshot      String
  optionGroupNameSnapshot  String?
  optionChoiceNameSnapshot String?
  partNumber               String
  frameNeeded              String
  quantity                 Int                     @default(1)
  bodyLeather              String?
  dueDate                  DateTime?
  priority                 OrderPriority           @default(NORMAL)
  currentStatus            ProductionOverallStatus @default(NEW)
  lineNotes                String?
  completedPhotoUrl        String?

  millFirstStatus          ProductionStageStatus   @default(NOT_STARTED)
  leatherOrderedStatus     ProductionStageStatus   @default(NOT_STARTED)
  millStatus               ProductionStageStatus   @default(NOT_STARTED)
  frameAssemblyStatus      ProductionStageStatus   @default(NOT_STARTED)
  leatherArrivedStatus     ProductionStageStatus   @default(NOT_STARTED)
  leaCutStatus             ProductionStageStatus   @default(NOT_STARTED)
  sewnStatus               ProductionStageStatus   @default(NOT_STARTED)
  upholsteryStatus         ProductionStageStatus   @default(NOT_STARTED)
  upholsteredStatus        ProductionStageStatus   @default(NOT_STARTED)
  finalAssemblyStatus      ProductionStageStatus   @default(NOT_STARTED)
  qcStatus                 ProductionStageStatus   @default(NOT_STARTED)

  leaCutAssignedTo         String?
  upholsteryAssignedTo     String?
  upholsteredAssignedTo    String?
  finalAssemblyAssignedTo  String?
  qcAssignedTo             String?

  pickedUp                 Boolean                 @default(false)
  pickedUpAt               DateTime?

  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt

  @@index([orderId])
  @@index([currentStatus])
  @@index([partNumber, frameNeeded])
  @@unique([orderId, partNumber, frameNeeded])
}

model QuantityLedger {
  id           String               @id @default(cuid())
  orderId      String
  order        Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderNumber  String
  poNumber     String?
  customerName String
  partNumber   String
  frameNeeded  String
  qtyChange    Int
  reason       QuantityLedgerReason
  source       String?
  createdAt    DateTime             @default(now())

  @@index([orderId])
  @@index([partNumber, frameNeeded])
  @@index([createdAt])
}

model Leather {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  grade          String
  imageUrl       String?
  inventoryUnits Decimal  @default(0) @db.Decimal(10, 2)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum UserRole {
  ADMIN
  STAFF
  CUSTOMER
}

enum OptionGroupType {
  SINGLE_SELECT
  MULTI_SELECT
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  CHANGED
  SENT_TO_FACTORY
  COMPLETED
  PAID
  CANCELLED
}

enum EmailLogType {
  ORDER_SUBMITTED
  ORDER_CHANGED
  FACTORY_SENT
}

enum OrderPriority {
  NORMAL
  RUSH
  HOLD
}

enum ProductionOverallStatus {
  NEW
  WAITING_ON_LEATHER
  CUTTING
  SEWING
  UPHOLSTERY
  FINAL_ASSEMBLY
  QC
  READY
  PICKED_UP
  BLOCKED
}

enum ProductionStageStatus {
  NOT_STARTED
  HOT
  IN_PROGRESS
  FRAME_DONE
  THIS_WEEK
  DONE
  MISSING_LEATHER
  BLOCKED
  NA
}

enum EmployeeDepartment {
  CUTTING
  SEWING
  UPHOLSTERY
  ASSEMBLY
  QC
  GENERAL
}

enum QuantityLedgerReason {
  ORDER_SENT_TO_FACTORY
  ORDER_EDITED
  ORDER_CANCELLED
  MANUAL_ADJUSTMENT
}