generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  role         UserRole @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
}

model Product {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description  String?
  sku          String?
  imageUrl String?
  basePrice    Decimal       @db.Decimal(10, 2)
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  optionGroups OptionGroup[]
  orderItems   OrderItem[]
}

model OptionGroup {
  id           String          @id @default(cuid())
  productId    String
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  type         OptionGroupType @default(SINGLE_SELECT)
  required     Boolean         @default(false)
  displayOrder Int             @default(0)
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  choices      OptionChoice[]

  @@unique([productId, slug])
}

model OptionChoice {
  id            String      @id @default(cuid())
  optionGroupId String
  optionGroup   OptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)
  label         String
  value         String?
  description   String?
  imageUrl      String?
  priceDelta    Decimal     @default(0) @db.Decimal(10, 2)

  usesLeatherGrades    Boolean  @default(false)
  isQuickPick Boolean  @default(false)
  allowsLaseredBrand Boolean @default(false)
  isBinaryOption Boolean @default(false)
  appliesLeatherSurcharge Boolean @default(true)
  gradeAUpcharge       Decimal? @db.Decimal(10, 2)
  gradeBUpcharge       Decimal? @db.Decimal(10, 2)
  gradeEMBUpcharge     Decimal? @db.Decimal(10, 2)
  gradeHOHUpcharge     Decimal? @db.Decimal(10, 2)
  gradeAxisUpcharge    Decimal? @db.Decimal(10, 2)
  gradeBuffaloUpcharge Decimal? @db.Decimal(10, 2)
  comUpcharge          Decimal? @db.Decimal(10, 2)

  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([optionGroupId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerName    String
  customerEmail   String
  customerPhone   String?
  poNumber String?
  frameNeededCode String?
  isBodyLeather Boolean @default(false)
  status          OrderStatus @default(DRAFT)
  subtotal        Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @default(0) @db.Decimal(10, 2)
  notes           String?
  sentToFactoryAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  items         OrderItem[]
  revisions     OrderRevision[]
  emailLogs     EmailLog[]
  sheetSyncLogs SheetSyncLog[]

  @@index([userId])
}

model OrderItem {
  id                  String               @id @default(cuid())
  orderId             String
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId           String
  product             Product              @relation(fields: [productId], references: [id])
  productNameSnapshot String
  basePriceSnapshot   Decimal              @db.Decimal(10, 2)
  quantity            Int                  @default(1)
  lineTotal           Decimal              @default(0) @db.Decimal(10, 2)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  selections          OrderItemSelection[]

  @@index([orderId])
}

model OrderItemSelection {
  id                       String    @id @default(cuid())
  orderItemId              String
  orderItem                OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  optionGroupNameSnapshot  String
  optionChoiceNameSnapshot String
  priceDeltaSnapshot       Decimal   @default(0) @db.Decimal(10, 2)
  createdAt                DateTime  @default(now())

  @@index([orderItemId])
}

model OrderRevision {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  revisionNumber Int
  changedBy      String?
  changeReason   String?
  beforeJson     Json
  afterJson      Json
  createdAt      DateTime @default(now())

  @@unique([orderId, revisionNumber])
  @@index([orderId])
}

model EmailLog {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventType    String
  recipient    String
  subject      String?
  status       String
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([orderId])
}

model SheetSyncLog {
  id               String   @id @default(cuid())
  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  spreadsheetId    String?
  worksheetName    String?
  spreadsheetRowId String?
  status           String
  errorMessage     String?
  createdAt        DateTime @default(now())

  @@index([orderId])
}

enum UserRole {
  ADMIN
  STAFF
  CUSTOMER
}

enum OptionGroupType {
  SINGLE_SELECT
  MULTI_SELECT
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  CHANGED
  SENT_TO_FACTORY
  COMPLETED
  CANCELLED
}

enum EmailLogType {
  ORDER_SUBMITTED
  ORDER_CHANGED
  FACTORY_SENT
}

model Leather {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  grade     String
  imageUrl  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
